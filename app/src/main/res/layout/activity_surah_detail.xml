<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- AppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_container"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_md">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:padding="8dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tvSurahName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Al-Fatihah"
            android:textSize="@dimen/text_headline_sm"
            android:textColor="@color/on_surface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVerseCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7 Verses"
            android:textSize="@dimen/text_body_md"
            android:textColor="@color/on_surface_variant" />

    </LinearLayout>

    <!-- Overall Progress bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_container"
        android:paddingBottom="@dimen/spacing_md">

        <TextView
            android:id="@+id/tvProgressLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OVERALL PROGRESS"
            android:textSize="@dimen/text_label_caps"
            android:textColor="@color/on_surface_variant"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardBackgroundColor="@color/primary"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0% Completed"
                    android:textSize="@dimen/text_headline_sm"
                    android:textColor="@color/on_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_sm" />

                <ProgressBar
                    android:id="@+id/progressSurah"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="0"
                    android:progressTint="@color/secondary_container"
                    android:progressBackgroundTint="#33FFFFFF" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/loadingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/primary" />

    <!-- Ayat list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVerses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/spacing_container"
        android:paddingBottom="@dimen/spacing_md"
        android:clipToPadding="false" />

    <!-- Tombol Mulai Game -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartGame"
        style="@style/Widget.SambungAyat.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="@dimen/spacing_container"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:text="Mulai Sambung Ayat" />

</LinearLayout>
