<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- AppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_container"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_md">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chevron_right"
            android:rotation="180"
            android:padding="8dp"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSurahName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sambung Ayat"
                android:textSize="@dimen/text_headline_sm"
                android:textColor="@color/on_surface"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAyatProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayat 1 dari 7"
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/on_surface_variant" />

        </LinearLayout>

        <!-- Score + Combo + Streak -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="@dimen/text_headline_sm"
                    android:textColor="@color/secondary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCORE"
                    android:textSize="10sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.05" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvCombo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="x1"
                    android:textSize="@dimen/text_headline_sm"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMBO"
                    android:textSize="10sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.05" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="@dimen/text_headline_sm"
                    android:textColor="@color/tertiary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STREAK"
                    android:textSize="10sp"
                    android:textColor="@color/on_surface_variant"
                    android:letterSpacing="0.05" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_variant"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- Instruksi -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Drag kata-kata di bawah menjadi ayat yang benar"
        android:textSize="@dimen/text_body_md"
        android:textColor="@color/on_surface_variant"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_container"
        android:layout_marginBottom="@dimen/spacing_md" />

    <!-- RecyclerView kata -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWords"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="@dimen/spacing_container"
        android:clipToPadding="false" />

    <!-- Feedback card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_container"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="0dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md"
            android:textSize="@dimen/text_body_lg"
            android:textColor="@color/on_surface"
            android:gravity="center" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Tombol Periksa -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPeriksa"
        style="@style/Widget.SambungAyat.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="@dimen/spacing_container"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:text="Periksa" />

</LinearLayout>
